# ncaster environment configuration
# Copy this file to .env and fill in your own values.
# The .env file is gitignored — never commit real keys.

# --- OpenAI ---------------------------------------------------------------
# API key used for AI-assisted features (e.g. generating titles, descriptions,
# hashtags, chapters, and summaries for social media / YouTube from transcripts).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model used for those AI features (optional; sensible default below).
OPENAI_MODEL=gpt-4o-mini
