# ncaster environment configuration
# Copy this file to .env and fill in your own values.
# The .env file is gitignored — never commit real keys.

# --- OpenAI ---------------------------------------------------------------
# API key used ONLY for text-based AI features that work on top of an already
# generated transcript: titles, descriptions, hashtags, chapters, summaries.
#
# Transcription itself stays 100% LOCAL (via Whisper) — no audio is ever sent
# to OpenAI. This key is optional; leave it unset if you don't use those features.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model used for those AI features (optional; sensible default below).
OPENAI_MODEL=gpt-4o-mini
